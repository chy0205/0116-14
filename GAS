  // 抓取整個分頁的資料跳過第一行標題
  const list = sheet.getDataRange().getValues().slice(1).filter(r => {
    // 【修正 2】因為分頁等於今天，不需要再判斷是不是今天了！
    // 只需要判斷權限 (Admin, Teacher 可以看全部，其他人只能看自己那組)
    const safeRole = role || '';
    return (safeRole.includes('Admin') || safeRole.includes('Teacher') || r[1] == userGroup);
    
   }).map(r => {
      // 這裡完全改掉：一律強制使用 Utilities.formatDate 轉成 "HH:mm" 時間格式
      let extractedTime = "??:??";
      try {
          if (r[0]) {
              extractedTime = Utilities.formatDate(new Date(r[0]), "GMT+8", "HH:mm");
          }
      } catch (e) {
          extractedTime = "--:--";
      }
      return { 
          group: r[1], 
          name: r[2], 
          time: extractedTime, 
          note: r[3] 
      };
  });
  
  return { success: true, data: list };
}
